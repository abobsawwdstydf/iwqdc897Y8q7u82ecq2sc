# API URL для подключения к серверу
# Для локальной разработки оставьте пустым или укажите http://localhost:3001
# Для доступа с телефона укажите IP вашего компьютера, например: http://192.168.0.100:3001
# Для продакшена укажите ваш домен: https://api.yourdomain.com
VITE_API_URL=

# Включение/отключение звуков
VITE_ENABLE_SOUNDS=true
