# ============================================
# 🚀 Nexo - Единый конфиг
# ============================================
# Автор: haker_one
# Версия: 2.0.0
# ============================================

# ----- Server -----
NODE_ENV=production
PORT=3001

# ----- Database -----
# ДЛЯ RENDER:
# 1. Создай PostgreSQL на render.com
# 2. Скопируй "External Database URL"
# 3. Вставь сюда
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ----- JWT & Encryption -----
# Сгенерируй новые ключи для безопасности:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_32_chars
ENCRYPTION_KEY=your_encryption_key_here_32_chars
MASTER_KEY=your_master_key_here_32_chars

# ----- CORS -----
# Для локалки: http://localhost:5173,http://localhost:3000
# Для продакшена: *
CORS_ORIGINS=*

# ----- Rate Limits -----
MAX_REGISTRATIONS_PER_IP=22

# ----- File Storage -----
# 50GB = 53687091200 байт
MAX_FILE_SIZE=53687091200
# Размер чанка: 19MB
CHUNK_SIZE=19922944

# ============================================
# 📱 TELEGRAM - Инструкция по получению
# ============================================
# 1. Открой @BotFather в Telegram
# 2. Отправь /newbot
# 3. Придумай имя и username (должен заканчиваться на bot)
# 4. Скопируй токен
#
# 5. Создай канал
# 6. Добавь бота как администратора
#
# 7. Добавь @RawDataBot в канал
# 8. Скопируй id из сообщения (например: -1001234567890)
# 9. Удали @RawDataBot
# ============================================

TELEGRAM_BOT_TOKENS=bot_token_1,bot_token_2,bot_token_3
# Формат: token1,token2,token3
# Пример: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz,2345678901:BCdefGHIjklMNOpqrsTUVwxyzA

TELEGRAM_CHANNEL_IDS=-1001234567890,-1002345678901
# Формат: id1,id2,id3
# Пример: -1001234567890,-1002345678901,-1003456789012

# ============================================
# 💬 DISCORD - Инструкция по получению
# ============================================
# 1. Открой Discord
# 2. Зайди на сервер → настройки канала (⚙️)
# 3. Интеграции → Вебхуки
# 4. Создать вебхук
# 5. Скопируй URL вебхука
# ============================================

DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/123/abc,https://discord.com/api/webhooks/456/def
# Формат: url1,url2,url3
# Пример: https://discord.com/api/webhooks/123/abc,https://discord.com/api/webhooks/456/def

# ============================================
# 🛡️ Admin Panel
# ============================================
# URL: /aaddmmiinnppaanneell
# Пароль: qwertyuiopasd
ADMIN_TOKEN=your_admin_password

# ============================================
# 📝 Шпаргалка
# ============================================
# 1. Заполни DATABASE_URL
# 2. Добавь TELEGRAM_BOT_TOKENS (хотя бы 1)
# 3. Добавь TELEGRAM_CHANNEL_IDS (хотя бы 1)
# 4. Добавь DISCORD_WEBHOOK_URLS (опционально)
# 5. Запусти: npm install && npm run dev
# ============================================
