# Registration protection (anti-spam)
# 0 = disabled, >0 = max registrations per IP per day
MAX_REGISTRATIONS_PER_IP=5

# Require email verification for registration (recommended for production)
REQUIRE_EMAIL_VERIFICATION=false

# Simple math captcha after N failed attempts
CAPTCHA_AFTER_FAILURES=3

