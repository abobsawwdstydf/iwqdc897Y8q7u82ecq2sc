generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  displayName String   @default("")
  email       String?  @unique
  phone       String?
  password    String
  avatar      String?
  bio         String?
  birthday    String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now())
  isOnline    Boolean  @default(false)
  hideStoryViews Boolean @default(false)
  registrationIp String?
  isVerified  Boolean  @default(false) // Галочка верификации

  messages    Message[]
  chatMembers ChatMember[]
  reactions   Reaction[]
  readReceipts ReadReceipt[]
  forwardedMessages Message[] @relation("ForwardedFrom")
  stories     Story[]
  storyViews  StoryView[]
  friendshipsSent     Friendship[] @relation("FriendshipsSent")
  friendshipsReceived Friendship[] @relation("FriendshipsReceived")
  liveStreamsSent     LiveStream[]
  
  // Папки чатов
  chatFolders ChatFolder[]
  
  // Черновики
  drafts Draft[]
  
  // Боты
  ownedBots Bot[] @relation("BotOwner")
  botAuthTokens BotAuthToken[]
  botAuths BotAuth[]
  
  // Стикеры
  favoriteStickerPacks UserStickerPack[]
  customStickerPacks StickerPack[] @relation("StickerPackOwner")
  
  // Анимированные эмодзи
  customEmojiPacks CustomEmojiPack[] @relation("CustomEmojiPackOwner")
  favoriteEmojiPacks UserCustomEmojiPack[]
  
  // Секретные чаты
  secretChatsSent SecretChat[] @relation("SecretChatSender")
  secretChatsReceived SecretChat[] @relation("SecretChatReceiver")
}

model Chat {
  id        Int      @id @default(autoincrement())
  type      String   @default("personal") // personal, group, channel, favorites, secret
  name      String?
  username  String?  @unique
  avatar    String?  // Main avatar (backward compatibility)
  description String?
  isPublic  Boolean  @default(false) // Для каналов: публичный/приватный
  inviteLink String? @unique // Ссылка-приглашение для каналов/групп
  createdAt DateTime @default(now())

  members        ChatMember[]
  messages       Message[]
  pinnedMessages PinnedMessage[]
  liveStreams    LiveStream[]
  avatars        ChatAvatar[]
  
  // Подписчики для каналов
  subscribers    ChannelSubscriber[]
  
  // Секретные чаты
  secretChat     SecretChat?
}

model ChatAvatar {
  id        Int      @id @default(autoincrement())
  chatId    Int
  url       String
  position  Int      @default(0)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, position])
}

model ChatMember {
  id         Int      @id @default(autoincrement())
  chatId     Int
  userId     Int
  role       String   @default("member") // member, admin, co-owner, owner
  joinedAt   DateTime @default(now())
  isMuted    Boolean  @default(false)
  isArchived Boolean  @default(false)
  isPinned   Boolean  @default(false)
  clearedAt  DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model LiveStream {
  id          Int      @id @default(autoincrement())
  chatId      Int
  ownerId     Int
  streamUrl   String?
  isLive      Boolean  @default(false)
  streamType  String   @default("video") // video, screen, app, window
  viewerCount Int      @default(0)
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  title       String?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Message {
  id        Int      @id @default(autoincrement())
  chatId    Int
  senderId  Int
  content   String?
  type      String   @default("text")
  replyToId Int?
  quote     String?
  forwardedFromId Int?
  isEdited  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  scheduledAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat    Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender  User     @relation(fields: [senderId], references: [id])
  replyTo Message? @relation("Reply", fields: [replyToId], references: [id])
  replies Message[] @relation("Reply")
  forwardedFrom User? @relation("ForwardedFrom", fields: [forwardedFromId], references: [id])

  media          Media[]
  reactions      Reaction[]
  readBy         ReadReceipt[]
  pinnedIn       PinnedMessage[]
  hiddenBy       HiddenMessage[]
}

model Media {
  id        Int      @id @default(autoincrement())
  messageId Int
  type      String
  url       String
  filename  String?
  thumbnail String?
  size      Int?
  duration  Float?
  width     Int?
  height    Int?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model ReadReceipt {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model PinnedMessage {
  id        Int      @id @default(autoincrement())
  chatId    Int
  messageId Int
  pinnedAt  DateTime @default(now())

  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([chatId, messageId])
}

model Story {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   @default("text")
  mediaUrl  String?
  content   String?
  bgColor   String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views StoryView[]
}

model StoryView {
  id       Int      @id @default(autoincrement())
  storyId  Int
  userId   Int
  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([storyId, userId])
}

model HiddenMessage {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  hiddenAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Friendship {
  id        Int      @id @default(autoincrement())
  userId    Int
  friendId  Int
  status    String   @default("pending") // pending | accepted | declined
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("FriendshipsSent", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipsReceived", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

// ============================================
// 📁 ПАПКИ ЧАТОВ
// ============================================
model ChatFolder {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String   // "Личное", "Работа", "Каналы"
  color     String?  @default("#6366f1")
  icon      String?  @default("folder")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats    ChatFolderChat[]
  
  @@unique([userId, name])
}

model ChatFolderChat {
  id        Int      @id @default(autoincrement())
  folderId  Int
  chatId    Int
  position  Int      @default(0)
  createdAt DateTime @default(now())
  
  folder ChatFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  
  @@unique([folderId, chatId])
}

// ============================================
// 📝 ЧЕРНОВИКИ
// ============================================
model Draft {
  id        Int      @id @default(autoincrement())
  userId    Int
  chatId    Int?     // null = черновик для нового чата
  content   String   @default("")
  media     Json?    // [{url, type, filename}]
  updatedAt DateTime @default(now()) @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// 🤖 БОТЫ
// ============================================
model Bot {
  id          Int      @id @default(autoincrement())
  ownerId     Int
  username    String   @unique
  name        String
  description String?
  avatar      String?
  apiToken    String   @unique
  webhookUrl  String?
  isVerified  Boolean  @default(false)
  isPrivate   Boolean  @default(false) // Приватный бот (только для владельца)
  createdAt   DateTime @default(now())
  lastActive  DateTime @default(now())
  
  owner       User      @relation("BotOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  commands    BotCommand[]
  authTokens  BotAuthToken[]
  logs        BotLog[]
}

model BotCommand {
  id        Int      @id @default(autoincrement())
  botId     Int
  command   String   // "/start", "/help"
  description String?
  handler   String?  // URL хендлера или inline-код
  createdAt DateTime @default(now())
  
  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)
  
  @@unique([botId, command])
}

model BotAuthToken {
  id        Int      @id @default(autoincrement())
  botId     Int
  userId    Int
  token     String   @unique
  expiresAt DateTime?
  createdAt DateTime @default(now())
  
  bot  Bot @relation(fields: [botId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BotAuth {
  id        Int      @id @default(autoincrement())
  userId    Int
  botId     Int
  permissions Json?  // ["read", "write", "admin"]
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, botId])
}

model BotLog {
  id        Int      @id @default(autoincrement())
  botId     Int
  level     String   @default("info") // info, warning, error
  message   String
  data      Json?
  createdAt DateTime @default(now())
  
  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)
}

// ============================================
// 🎭 СТИКЕРЫ
// ============================================
model StickerPack {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  name      String   @unique
  title     String
  description String?
  avatar    String?
  isAnimated Boolean @default(false)
  isOfficial Boolean @default(false)
  createdAt DateTime @default(now())
  
  owner    User     @relation("StickerPackOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  stickers Sticker[]
  users    UserStickerPack[]
}

model Sticker {
  id        Int      @id @default(autoincrement())
  packId    Int
  emoji     String?  // Эмодзи, ассоциированный со стикером
  url       String
  thumbnail String?
  isAnimated Boolean @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  
  pack StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  
  @@unique([packId, position])
}

model UserStickerPack {
  id        Int      @id @default(autoincrement())
  userId    Int
  packId    Int
  isFavorite Boolean @default(true)
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  
  @@unique([userId, packId])
}

// ============================================
// ✨ АНИМИРОВАННЫЕ ЭМОДЗИ
// ============================================
model CustomEmojiPack {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  name      String   @unique
  title     String
  description String?
  avatar    String?
  createdAt DateTime @default(now())
  
  owner    User            @relation("CustomEmojiPackOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  emojis   CustomEmoji[]
  users    UserCustomEmojiPack[]
}

model CustomEmoji {
  id        Int      @id @default(autoincrement())
  packId    Int
  emoji     String   @unique // Уникальный идентификатор эмодзи
  url       String   // URL анимации (TGS/Lottie)
  thumbnail String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  
  pack CustomEmojiPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  
  @@unique([packId, position])
}

model UserCustomEmojiPack {
  id        Int      @id @default(autoincrement())
  userId    Int
  packId    Int
  isFavorite Boolean @default(true)
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack CustomEmojiPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  
  @@unique([userId, packId])
}

// ============================================
// 🔒 СЕКРЕТНЫЕ ЧАТЫ
// ============================================
model SecretChat {
  id           Int      @id @default(autoincrement())
  chatId       Int      @unique
  senderId     Int
  receiverId   Int
  encryptionKey String  @unique // Ключ шифрования
  ttl          Int      @default(60) // Время жизни сообщений в секундах
  isDestroyed  Boolean  @default(false)
  createdAt    DateTime @default(now())
  destroyedAt  DateTime?
  
  chat     Chat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender   User  @relation("SecretChatSender", fields: [senderId], references: [id], onDelete: Restrict)
  receiver User  @relation("SecretChatReceiver", fields: [receiverId], references: [id], onDelete: Restrict)
  messages SecretMessage[]
}

model SecretMessage {
  id        Int      @id @default(autoincrement())
  chatId    Int
  senderId  Int
  content   String   // Зашифрованное содержимое
  isRead    Boolean  @default(false)
  expiresAt DateTime // Когда удалить
  createdAt DateTime @default(now())
  deletedAt DateTime?
  
  chat SecretChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

// ============================================
// 📢 ПОДПИСЧИКИ КАНАЛОВ
// ============================================
model ChannelSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    Int      // ID канала
  userId    Int
  isMuted   Boolean  @default(false)
  subscribedAt DateTime @default(now())
  
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  @@unique([chatId, userId])
}
