# ============================================
# 🌐 NIMBUS WEB CLIENT CONFIG
# ============================================

# Server URL (Render или локальный)
# Измените на ваш URL если запускаете локально
VITE_API_URL=https://nimbus-msg.onrender.com

# Storage URL (опционально, если отдельный сервер)
VITE_STORAGE_URL=https://nimbus-msg.onrender.com

# App Settings
VITE_APP_NAME=Nimbus Messenger
VITE_APP_VERSION=1.0.0

# Features
VITE_ENABLE_ENCRYPTION=true
VITE_ENABLE_DISTRIBUTED_STORAGE=true

# ============================================
# 📝 Для локальной разработки измените:
# VITE_API_URL=http://localhost:3001
# VITE_STORAGE_URL=http://localhost:3002
# ============================================
